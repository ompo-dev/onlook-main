{
  "name": "@onlook/cssstudio-runtime",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "main": "./index.mjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "scripts": {
    "mcp": "bun ./vendor/cli.mjs",
    "sync:upstream": "bun ./scripts/sync-upstream-cssstudio.mjs",
    "rebuild:bundle": "bun ./scripts/rebuild-cssstudio.mjs",
    "build:src": "node ./scripts/build-src.mjs",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "cssstudio-local": "./vendor/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "default": "./index.mjs"
    },
    "./cli": "./vendor/cli.mjs"
  },
  "files": [
    "dist/*.js",
    "dist/*.mjs",
    "dist/*.css",
    "vendor/*.mjs",
    "vendor/*.css"
  ],
  "dependencies": {
    "motion": "^12.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
